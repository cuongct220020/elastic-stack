version: '3.8'

services:
  # ===========================
  # 1) Elasticsearch (Single Node)
  # ===========================
  es01:
    image: elasticsearch:9.2.1
    container_name: es01
    environment:
      - node.name=es01
      - cluster.name=dev-single-node
      - discovery.type=single-node     # Loại bỏ cluster logic, chạy nhẹ nhất

      # Giảm tối đa heap
      - ES_JAVA_OPTS=-Xms512m -Xmx512m

      # Tắt toàn bộ X-Pack nặng
      - xpack.security.enabled=false
      - xpack.ml.enabled=false
      - xpack.watcher.enabled=false
      - xpack.monitoring.collection.enabled=false
      - xpack.security.enrollment.enabled=false
      - xpack.license.self_generated.type=basic

      # Giảm tiêu thụ RAM + CPU
      - bootstrap.memory_lock=false
      - indices.memory.index_buffer_size=5%
      - thread_pool.write.size=1
      - thread_pool.search.size=1

      # Giảm tần suất refresh (tối ưu cho ingest)
      - index.refresh_interval=10s

      # Tắt audit & các tính năng ngầm
      - logger.org.elasticsearch.transport=false
      - logger.org.elasticsearch.discovery=false

    ulimits:
      nofile:
        soft: 65536
        hard: 65536

    volumes:
      - esdata01:/usr/share/elasticsearch/data

    ports:
      - "9200:9200"

    networks:
      - elastic

  # ===========================
  # 2) Kibana (Lightweight)
  # ===========================
  kibana:
    image: kibana:9.2.1
    container_name: kibana
    environment:
      - SERVERNAME=kibana
      - ELASTICSEARCH_HOSTS=http://es01:9200

      # Tắt security
      - XPACK_SECURITY_ENABLED=false

      # Giảm RAM tối đa xuống 384–512MB
      - NODE_OPTIONS=--max-old-space-size=384

      # Giảm log
      - LOGGING_ROOT_LEVEL=error
      - TELEMETRY_ENABLED=false

    ports:
      - "5601:5601"

    depends_on:
      - es01

    networks:
      - elastic
    volumes:
      - kibanadata:/usr/share/kibana/data

# ========================
volumes:
  esdata01:
  kibanadata:

networks:
  elastic:
    driver: bridge
