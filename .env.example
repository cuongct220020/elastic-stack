# ===== Elastic =====
STACK_VERSION=9.3.1
CLUSTER_NAME=elastic-cluster
LICENSE=basic
#LICENSE=trial

# ===== ELASTICSEARCH =====
# Password for the 'elastic' user (at least 6 characters)
ELASTIC_PASSWORD=
ES_PORT=9200

# ES Memory Limit, must be ≤ half of ES_MEM_LIMIT  (e.g. 1g heap- -> 2g container limit)
ES_HEAP_SIZE=1g
ES_MEM_LIMIT=2g

# ===== KIBANA =====
# Password for the 'kibana_system' user (at least 6 characters)
KIBANA_PASSWORD=
KIBANA_PORT=5601
KIBANA_MEM_LIMIT=1g
KIBANA_ENCRYPTION_KEY=
KIBANA_REPORTING_KEY=
KIBANA_SECURITY_KEY=

# ===== Logstash =====
LOGSTASH_BEATS_PORT=5044
LOGSTASH_TCP_PORT=5000
LOGSTASH_UDP_PORT=5000
LOGSTASH_API_PORT=9600

LOGSTASH_PIPELINE_WORKERS=2
LOGSTASH_PIPELINE_BATCH_SIZE=250
LOGSTASH_PIPELINE_BATCH_DELAY=50

# ===== Fleet & Agent Server =====
FLEET_SERVER_PORT=8220
FLEET_SERVER_SERVICE_TOKEN=
FLEET_SERVER_POLICY_ID=fleet-server-policy
FLEET_MEM_LIMIT=512m

ELASTIC_AGENT_ENROLLMENT_TOKEN=
ELASTIC_AGENT_MEM_LIMIT=256m

# ===== MINIO =====
MINIO_VERSION=RELEASE.2024-03-05T04-48-44Z
MINIO_API_PORT=9000
MINIO_WEBUI_PORT=9001
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# ===== APP BACKEND =====
APP_VERSION=1.0.0
MONGO_VERSION=7.0
MONGO_ROOT_USER=
MONGO_ROOT_PASSWORD=
NGINX_VERSION=1.25
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443