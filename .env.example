# Version of Elastic products
STACK_VERSION=9.3.1

# Set the cluster name
CLUSTER_NAME=elastic-cluster

# Set to 'basic' or 'trial' to automatically start the 30-day trial
LICENSE=basic
#LICENSE=trial

##### ELASTICSEARCH #####
# Password for the 'elastic' user (at least 6 characters)
ELASTIC_PASSWORD=

# Port to expose Elasticsearch HTTP API to the host
ES_PORT=9200
#ES_PORT=127.0.0.1:9200


##### KIBANA #####
# Password for the 'kibana_system' user (at least 6 characters)
KIBANA_PASSWORD=

# Port to expose Kibana to the host
KIBANA_PORT=5601
#KIBANA_PORT=80


# Kibana encryption keys  (generate: openssl rand -hex 32)
KIBANA_ENCRYPTION_KEY=
KIBANA_REPORTING_KEY=
KIBANA_SECURITY_KEY=


##### Fleet Server #####
FLEET_SERVER_PORT=8220

# Generate via Kibana UI: Fleet → Settings → Generate service token
# Or via API:
#   curl -X POST --cacert ca.crt -u elastic:<password> \
#     https://localhost:9200/_security/service/elastic/fleet-server/credential/token/fleet-token
FLEET_SERVER_SERVICE_TOKEN=

# Policy ID created in Kibana Fleet UI (or leave default)
FLEET_SERVER_POLICY_ID=fleet-server-policy

# Elastic Agent enrollment token, generate via Kibana UI: Fleet → Enrollment tokens → Create
ELASTIC_AGENT_ENROLLMENT_TOKEN=


##### Memory limits #####
# Must be ≤ half of ES_MEM_LIMIT  (e.g. 1g heap → 2g container limit)
ES_HEAP_SIZE=1g
ES_MEM_LIMIT=2g
KIBANA_MEM_LIMIT=1g
FLEET_MEM_LIMIT=512m
AGENT_MEM_LIMIT=256m