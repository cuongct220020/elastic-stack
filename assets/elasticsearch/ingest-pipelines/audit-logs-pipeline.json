{
  "description": "Audit Logs Pipeline - Parse JSON and User Agent",
  "_meta": {
    "version": "1.2.0",
    "managed_by": "gitops-workflow"
  },
  "processors": [
    {
      "json": {
        "field": "message",
        "add_to_root": true,
        "ignore_failure": true
      }
    },
    {
      "user_agent": {
        "field": "user_agent.original",
        "target_field": "user_agent",
        "ignore_missing": true
      }
    },
    {
      "remove": {
        "field": ["message", "agent", "log.file.path"],
        "ignore_missing": true,
        "ignore_failure": true
      }
    }
  ]
}