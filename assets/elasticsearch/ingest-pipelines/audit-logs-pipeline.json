{
  "description": "Audit Logs Pipeline - Advanced Parsing",
  "_meta": {
    "version": "1.1.0",
    "managed_by": "gitops-workflow"
  },
  "processors": [
    {
      "user_agent": {
        "field": "user_agent.original",
        "target_field": "user_agent",
        "ignore_missing": true
      }
    },
    {
      "remove": {
        "field": ["agent", "log.file.path", "message"],
        "ignore_missing": true,
        "ignore_failure": true
      }
    }
  ]
}