{
  "description": "Pipeline bóc tách Linux Audit logs sang chuẩn ECS",
  "_meta": {
    "version": "1.0.1",
    "managed_by": "gitops-workflow"
  },
  "processors": [
    {
      "grok": {
        "field": "message",
        "patterns": [
          "%{WORD:audit.type} %{GREEDYDATA:audit.message}"
        ],
        "ecs_compatibility": "v1"
      }
    },
    {
      "set": {
        "field": "event.module",
        "value": "audit_system"
      }
    }
  ]
}